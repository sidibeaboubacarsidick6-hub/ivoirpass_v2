# ============================================
# IVOIRPASS V2 - Variables d'environnement
# EXEMPLE - Copiez ce fichier en .env et remplissez les valeurs
# ============================================

# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
DB_NAME=ivoirpass_v2_db
DB_USER=ivoirpass_v2_user
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# EMAIL — Gmail SMTP (développement)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here

# CinetPay (à configurer)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# Environnement
DJANGO_SETTINGS_MODULE=config.settings.development

# ============================================
# PAYDUNYA - Paiement
# ============================================
PAYDUNYA_MASTER_KEY=your-paydunya-master-key
PAYDUNYA_PRIVATE_KEY=your-paydunya-private-key
PAYDUNYA_TOKEN=your-paydunya-token
PAYDUNYA_MODE=test
PAYDUNYA_BASE_URL=https://your-ngrok-url.ngrok-free.dev

# ============================================
# EMAIL — SendGrid (production)
# ============================================
SENDGRID_API_KEY=

# ============================================
# SMS — Orange CI / Twilio
# ============================================
ORANGE_SMS_CLIENT_ID=
ORANGE_SMS_CLIENT_SECRET=
ORANGE_SMS_SENDER_NAME=IvoirPass

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

SMS_ENABLED=False
